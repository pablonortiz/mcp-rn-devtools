{
  "name": "mcp-rn-devtools-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
