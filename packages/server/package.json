{
  "name": "mcp-rn-devtools",
  "version": "0.1.0",
  "description": "MCP server for React Native runtime debugging — gives Claude access to logs, errors, network, and navigation from your running app",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-rn-devtools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "mcp",
    "react-native",
    "devtools",
    "debugging",
    "claude",
    "hermes"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "source-map": "^0.7.6",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@mcp-rn-devtools/shared": "workspace:*",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
