{
  "name": "mcp-rn-devtools-sdk",
  "version": "0.1.0",
  "description": "React Native SDK for mcp-rn-devtools — adds network interception, navigation state, and more to your running app",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "react-native",
    "devtools",
    "mcp",
    "debugging",
    "network",
    "navigation"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@mcp-rn-devtools/shared": "workspace:*",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
